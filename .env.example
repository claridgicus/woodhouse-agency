# Required environment variables for production Vercel deployment
# Set these in the Vercel dashboard under Project > Settings > Environment Variables

# HubSpot — Portal ID (found in HubSpot account settings)
PUBLIC_HUBSPOT_PORTAL_ID=

# HubSpot — AI Readiness Assessment form GUID
PUBLIC_HUBSPOT_FORM_GUID=

# HubSpot — ROI Calculator form GUID
PUBLIC_HUBSPOT_ROI_FORM_GUID=
